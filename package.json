{
  "name": "ccparse-sdk",
  "version": "0.1.0-alpha.1",
  "description": "Fault-tolerant TypeScript SDK for discovering, parsing, normalizing, and querying Claude Code local session data.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puukis/ccparse.git"
  },
  "homepage": "https://github.com/puukis/ccparse#readme",
  "bugs": {
    "url": "https://github.com/puukis/ccparse/issues"
  },
  "packageManager": "npm@11.12.1",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "test:coverage": "node --import tsx --test --experimental-test-coverage tests/**/*.test.ts",
    "check": "npm run typecheck && npm run test",
    "example:basic": "node --import tsx examples/basic-usage.ts",
    "example:discovery": "node --import tsx examples/discover-sessions.ts",
    "example:open-tool-calls": "node --import tsx examples/inspect-open-tool-calls.ts",
    "example:tool-results": "node --import tsx examples/resolve-tool-results.ts",
    "audit:local-edge-cases": "node --import tsx scripts/audit-local-edge-cases.ts",
    "fixtures:validate": "node --import tsx scripts/validate-fixtures.ts",
    "prepublishOnly": "npm run build && npm run check"
  },
  "keywords": [
    "claude-code",
    "transcript",
    "jsonl",
    "parser",
    "sdk",
    "typescript"
  ],
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
